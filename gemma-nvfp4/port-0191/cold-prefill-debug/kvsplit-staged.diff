+@pytest.mark.parametrize("num_heads", NUM_HEADS)  # (5,1) -> BLOCK_Q=3, worst packing
+@pytest.mark.parametrize("head_size", [128, 256, 512])
+@pytest.mark.parametrize("block_size", BLOCK_SIZES)
+# sliding_window smaller than the query span over deep KV forces a fully
+# SW-masked tail segment for early rows -> exercises the m_j=-inf / expsum==0 guards
+@pytest.mark.parametrize("sliding_window", [None, 64, 256])
+@pytest.mark.parametrize("soft_cap", [None, 50.0])
+@torch.inference_mode()
+def test_triton_unified_attn_3d_large_query(
+    seq_lens: list[tuple[int, int]],
+    num_heads: tuple[int, int],
+    head_size: int,
+    sliding_window: int | None,
+    block_size: int,
+    soft_cap: float | None,
+    monkeypatch: pytest.MonkeyPatch,
+) -> None:
+    import vllm.v1.attention.ops.triton_unified_attention as tua
