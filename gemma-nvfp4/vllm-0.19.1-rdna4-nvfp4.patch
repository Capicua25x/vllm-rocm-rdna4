+
+# =============================================================================
+# NVFP4 Linear Kernel — runtime dequant + matmul for RDNA3/RDNA4
+#
+# Same E2M1→FP16 bit-manipulation dequant as fused_moe_nvfp4_kernel above,
+# but for standard Linear layers (no expert routing). Keeps weights packed
+# as uint8 in VRAM instead of dequanting to bf16 at load time.
+# =============================================================================
+
+_RDNA_NVFP4_LINEAR_DEFAULT_CONFIG = {
+    "BLOCK_SIZE_M": 64,
+    "BLOCK_SIZE_N": 64,
+    "BLOCK_SIZE_K": 64,
+    "GROUP_SIZE_M": 8,
