+# =============================================================================
+# Fused NVFP4 MoE Kernel - dequant + matmul in single Triton kernel
+#
+# Hand-built for AMD ROCm (gfx11/gfx12, RDNA3/RDNA4) where no NVIDIA-specific
+# FP4 tensor-core path exists. Uses LINEAR scale layout (no swizzling).
+#
+# Scale format (native NVFP4):
+#   b_scale       : fp8_e4m3fn, shape [E, N, K//16]  per-group block scales
+#   b_scale_global: fp32,        shape [E]            1 / w_global_scale
+#
+# Kernel dequant pipeline (per element):
+#   fp8_scale  -> fp32  (tl cast)
+#   effective  = fp32_scale * b_scale_global[expert]
+#   weight_val = fp4_e2m1 decode * effective
+# =============================================================================
+
+
+@triton.jit
+def fused_moe_nvfp4_kernel(
+    a_ptr,
+    b_packed_ptr,
+    c_ptr,
+    b_scale_ptr,
+    b_scale_global_ptr,
+    topk_weights_ptr,
+    sorted_token_ids_ptr,
+    expert_ids_ptr,
+    num_tokens_post_padded_ptr,
+    N,
+    K,
+    EM,
+    num_valid_tokens,
+    stride_am,
+    stride_ak,
+    stride_bpe,
+    stride_bpn,
+    stride_bpk,
+    stride_cm,
+    stride_cn,
+    stride_bse,
+    stride_bsn,
+    stride_bsk,
+    stride_bsge,
+    BLOCK_SIZE_M: tl.constexpr,
+    BLOCK_SIZE_N: tl.constexpr,
+    BLOCK_SIZE_K: tl.constexpr,
+    GROUP_SIZE_M: tl.constexpr,
+    MUL_ROUTED_WEIGHT: tl.constexpr,
+    top_k: tl.constexpr,
+    compute_type: tl.constexpr,
+):
+    tl.static_assert(BLOCK_SIZE_K % 16 == 0, "BLOCK_SIZE_K must be multiple of 16")
+
+    pid = tl.program_id(axis=0)
+    num_pid_m = tl.cdiv(EM, BLOCK_SIZE_M)
+    num_pid_n = tl.cdiv(N, BLOCK_SIZE_N)
+    num_pid_in_group = GROUP_SIZE_M * num_pid_n
+    group_id = pid // num_pid_in_group
+    first_pid_m = group_id * GROUP_SIZE_M
+    group_size_m = min(num_pid_m - first_pid_m, GROUP_SIZE_M)
+    pid_m = first_pid_m + ((pid % num_pid_in_group) % group_size_m)
+    pid_n = (pid % num_pid_in_group) // group_size_m
+
+    num_tokens_post_padded = tl.load(num_tokens_post_padded_ptr)
+    if pid_m * BLOCK_SIZE_M >= num_tokens_post_padded:
+        return
+
+    offs_token_id = pid_m * BLOCK_SIZE_M + tl.arange(0, BLOCK_SIZE_M).to(tl.int64)
+    offs_token = tl.load(sorted_token_ids_ptr + offs_token_id)
+    token_mask = offs_token < num_valid_tokens
+
+    off_experts = tl.load(expert_ids_ptr + pid_m).to(tl.int64)
+
+    if off_experts == -1:
+        offs_cn = pid_n * BLOCK_SIZE_N + tl.arange(0, BLOCK_SIZE_N)
+        c_ptrs = c_ptr + offs_token[:, None] * stride_cm + offs_cn[None, :] * stride_cn
+        c_mask = token_mask[:, None] & (offs_cn[None, :] < N)
+        tl.store(
+            c_ptrs,
+            tl.zeros((BLOCK_SIZE_M, BLOCK_SIZE_N), dtype=compute_type),
+            mask=c_mask,
+        )
+        return
+
+    # Per-expert global weight scale (= 1 / w_global_scale). Loaded once and
+    # narrowed to compute_type so the K-loop stays in fp16 / bf16 end-to-end.
+    scale_global = tl.load(b_scale_global_ptr + off_experts * stride_bsge)
+    scale_global = scale_global.to(compute_type)
+
+    offs_bn = (pid_n * BLOCK_SIZE_N + tl.arange(0, BLOCK_SIZE_N).to(tl.int64)) % N
+    offs_am_k = tl.arange(0, BLOCK_SIZE_K)
+    # Native packed layout: one unique byte per K-row (holds two E2M1 values).
+    offs_bk_packed = tl.arange(0, BLOCK_SIZE_K // 2)
+    # Native scale layout: one fp8 scale per 16 K elements.
+    offs_bk_scale = tl.arange(0, BLOCK_SIZE_K // 16)
+
+    a_ptrs = a_ptr + (
+        offs_token[:, None] // top_k * stride_am + offs_am_k[None, :] * stride_ak
+    )
+
+    b_packed_ptrs = (
+        b_packed_ptr
+        + off_experts * stride_bpe
+        + offs_bn[None, :] * stride_bpn
+        + offs_bk_packed[:, None] * stride_bpk
+    )
+
+    b_scale_ptrs = (
+        b_scale_ptr
+        + off_experts * stride_bse
+        + offs_bn[None, :] * stride_bsn
+        + offs_bk_scale[:, None] * stride_bsk
+    )
+
+    accumulator = tl.zeros((BLOCK_SIZE_M, BLOCK_SIZE_N), dtype=tl.float32)
+
+    for k in range(0, tl.cdiv(K, BLOCK_SIZE_K)):
+        k_start = k * BLOCK_SIZE_K
+        k_remaining = K - k_start
+
+        k_mask = offs_am_k < k_remaining
+
+        a = tl.load(
+            a_ptrs,
+            mask=token_mask[:, None] & k_mask[None, :],
+            other=0.0,
+        )
+
+        k_packed_mask = offs_bk_packed < ((k_remaining + 1) // 2)
+        b_packed = tl.load(
+            b_packed_ptrs,
+            mask=k_packed_mask[:, None],
+            other=0,
+        )  # [BLOCK_K // 2, BLOCK_N]
+
+        # Scale: fp8_e4m3fn native. On gfx12 this is a single V_CVT_*_FP8
+        # instruction; on gfx11 Triton emits a software decode. Fold in the
+        # per-expert global scale inline.
+        # NOTE: `other=0.0` (float, not int) — Triton requires a float zero so
+        # the default value can cast into fp8e4m3fn. A bare `0` is int32 and
+        # triggers "cannot cast int32 to fp8e4nv" at compile time.
+        k_scale_mask = offs_bk_scale < tl.cdiv(k_remaining, 16)
+        b_scale_fp8 = tl.load(
+            b_scale_ptrs,
+            mask=k_scale_mask[:, None],
+            other=0.0,
+        )  # [BLOCK_K // 16, BLOCK_N]
+        b_scale_group = b_scale_fp8.to(compute_type) * scale_global
+
+        # Transpose so K is the last axis (required for tl.interleave).
+        # Both transposes are register-resident shuffles, not memory ops.
+        b_packed_t = tl.trans(b_packed)        # [BLOCK_N, BLOCK_K // 2]
+        b_scale_gt = tl.trans(b_scale_group)   # [BLOCK_N, BLOCK_K // 16]
+
+        # Decode both nibbles of each byte in parallel via in-place bit
+        # manipulation (ported from triton_kernels/.../rdna_value.py). Operates
+        # on the packed byte directly — no nibble separation, no int32 promote,
+        # sign bit masked in place and OR'd with the mantissa shift.
+        # E2M1 -> FP16: bias=15, mant=10 bits, denormal ±0.5 at fp16 bits 0x3800
+        em0 = b_packed_t & 0x07                       # low-nibble exp+mant in place
+        em1 = b_packed_t & 0x70                       # high-nibble exp+mant in place
+        x0 = (em0.to(tl.uint16) << 9) | (
+            (b_packed_t & 0x08).to(tl.uint16) << 12
+        )                                              # low-nibble sign merged
+        x1 = (em1.to(tl.uint16) << 5) | (
+            (b_packed_t & 0x80).to(tl.uint16) << 8
+        )                                              # high-nibble sign merged
+        x0 = tl.where((em0 & 0x06) != 0, x0 + (14 << 10), x0)   # add fp16 bias for normals
+        x1 = tl.where((em1 & 0x60) != 0, x1 + (14 << 10), x1)
+        x0 = tl.where(em0 == 0x01, 0x3800 | (x0 & 0x8000), x0)  # denormal ±0.5 patch
+        x1 = tl.where(em1 == 0x10, 0x3800 | (x1 & 0x8000), x1)
+
+        # Byte k packs K=2k in low nibble, K=2k+1 in high. Interleave along the
+        # last (K) axis to restore original K order, then a single bitcast for
+        # the whole tile: [BLOCK_N, BLOCK_K]
+        fp_val_t = tl.interleave(x0, x1).to(tl.float16, bitcast=True)
+
+        # Broadcast [BLOCK_N, BLOCK_K // 16] -> [BLOCK_N, BLOCK_K] by
+        # replicating each scale 16 times. Pure register splat, no extra loads.
+        b_scale_3d = b_scale_gt[:, :, None]
+        b_scale_3d = tl.broadcast_to(
+            b_scale_3d, (BLOCK_SIZE_N, BLOCK_SIZE_K // 16, 16)
+        )
+        b_scale_full_t = tl.reshape(b_scale_3d, (BLOCK_SIZE_N, BLOCK_SIZE_K))
+
+        b_t = (fp_val_t * b_scale_full_t).to(compute_type)
+        b = tl.trans(b_t)  # [BLOCK_K, BLOCK_N]
+        b = tl.where(k_mask[:, None], b, 0.0)
+
+        accumulator += tl.dot(a, b)
+
+        a_ptrs += BLOCK_SIZE_K * stride_ak
+        b_packed_ptrs += (BLOCK_SIZE_K // 2) * stride_bpk
+        b_scale_ptrs += (BLOCK_SIZE_K // 16) * stride_bsk
+
+    if MUL_ROUTED_WEIGHT:
+        moe_weight = tl.load(topk_weights_ptr + offs_token, mask=token_mask, other=0)
+        accumulator = accumulator * moe_weight[:, None]
+
+    accumulator = accumulator.to(compute_type)
+
+    offs_cn = pid_n * BLOCK_SIZE_N + tl.arange(0, BLOCK_SIZE_N)
+    c_ptrs = c_ptr + stride_cm * offs_token[:, None] + stride_cn * offs_cn[None, :]
+    c_mask = token_mask[:, None] & (offs_cn[None, :] < N)
+    tl.store(c_ptrs, accumulator, mask=c_mask)
+
+
+def invoke_fused_moe_nvfp4_kernel(
+    A: torch.Tensor,
+    B_packed: torch.Tensor,
+    C: torch.Tensor,
+    B_scale: torch.Tensor,
+    B_scale_global: torch.Tensor,
+    topk_weights: torch.Tensor | None,
+    sorted_token_ids: torch.Tensor,
+    expert_ids: torch.Tensor,
+    num_tokens_post_padded: torch.Tensor,
+    mul_routed_weight: bool,
+    top_k: int,
+    config: dict,
+    compute_type: "tl.dtype",
+) -> None:
+    """Launch the fused NVFP4 MoE kernel.
+
+    A:              [M, K] activations (fp16/bf16)
+    B_packed:       [E, N, K//2] uint8 packed NVFP4 weights (two E2M1 per byte)
+    C:              [M, N] output (compute_type)
+    B_scale:        [E, N, K//16] fp8_e4m3fn per-group block scales (LINEAR layout)
+    B_scale_global: [E] fp32, one per expert (= 1 / w_global_scale); folded
+                    inline with B_scale during dequant.
+    """
+    assert B_packed.dtype == torch.uint8, "Weights must be packed uint8"
+    assert B_scale.dtype == torch.float8_e4m3fn, "B_scale must be fp8_e4m3fn"
+    assert B_scale_global.dtype == torch.float32, "B_scale_global must be fp32"
+    assert B_scale_global.ndim == 1, "B_scale_global must be 1-D [E]"
+    assert B_scale_global.size(0) == B_packed.size(0), (
+        "B_scale_global length must equal num experts"
+    )
+    assert topk_weights is not None or not mul_routed_weight
+
+    M = A.size(0)
+    num_tokens = M * top_k
+    E, N, packed_K = B_packed.shape
+    K = packed_K * 2
+
+    EM = sorted_token_ids.size(0)
+    if A.size(0) < config["BLOCK_SIZE_M"]:
+        EM = min(sorted_token_ids.size(0), A.size(0) * top_k * config["BLOCK_SIZE_M"])
+
+    grid = lambda META: (
+        triton.cdiv(EM, META["BLOCK_SIZE_M"]) * triton.cdiv(N, META["BLOCK_SIZE_N"]),
+    )
+
+    block_k = config.get("BLOCK_SIZE_K", 64)
+    if block_k % 16 != 0:
+        block_k = ((block_k + 15) // 16) * 16
+
+    fused_moe_nvfp4_kernel[grid](
+        A,
+        B_packed,
+        C,
+        B_scale,
+        B_scale_global,
+        topk_weights,
+        sorted_token_ids,
+        expert_ids,
+        num_tokens_post_padded,
+        N,
+        K,
+        EM,
+        num_tokens,
+        A.stride(0),
+        A.stride(1),
+        B_packed.stride(0),
+        B_packed.stride(1),
+        B_packed.stride(2),
+        C.stride(-2),
+        C.stride(-1),
+        B_scale.stride(0),
+        B_scale.stride(1),
+        B_scale.stride(2),
+        B_scale_global.stride(0),
+        MUL_ROUTED_WEIGHT=mul_routed_weight,
+        top_k=top_k,
+        compute_type=compute_type,
+        BLOCK_SIZE_M=config["BLOCK_SIZE_M"],
+        BLOCK_SIZE_N=config["BLOCK_SIZE_N"],
+        BLOCK_SIZE_K=block_k,
+        GROUP_SIZE_M=config.get("GROUP_SIZE_M", 8),
+    )
