+    _FP4_E2M1_LUT = torch.tensor([
+        0.0, 0.5, 1.0, 1.5, 2.0, 3.0, 4.0, 6.0,
+        -0.0, -0.5, -1.0, -1.5, -2.0, -3.0, -4.0, -6.0
+    ], dtype=torch.float32)
+
+    @staticmethod
+    def _dequant_mxfp4_to_dtype(weight_packed, scale, dtype):
+        lo = (weight_packed & 0x0F).to(torch.int64)
+        hi = ((weight_packed >> 4) & 0x0F).to(torch.int64)
+        lut = CompressedTensorsW4A16Mxfp4._FP4_E2M1_LUT.to(
+            weight_packed.device)
+        w = torch.stack([lut[lo], lut[hi]], dim=-1).reshape(
+            weight_packed.shape[0], weight_packed.shape[1] * 2)
+        # E8M0 scale: 2^(scale_uint8 - 127)
+        scale_fp = (scale.to(torch.int32) - 127).float().exp2()
+        scale_fp = scale_fp.repeat_interleave(32, dim=-1)  # group_size=32
+        if scale_fp.shape[-1] > w.shape[-1]:
+            scale_fp = scale_fp[:, :w.shape[-1]]
+        return (w * scale_fp).to(dtype)
+
