+        # TRITON path doesn't set moe_quant_config during
+        # process_weights_after_loading — set it now so
+        # apply_monolithic can pass it to triton_kernel_moe_forward
+        self._inner.moe_quant_config = (
+            self._inner.get_fused_moe_quant_config(layer))
+
+    def get_fused_moe_quant_config(
+        self, layer: torch.nn.Module,
+    ) -> FusedMoEQuantConfig | None:
+        return self._inner.get_fused_moe_quant_config(layer)
+
+    @property
+    def is_monolithic(self) -> bool:
+        return self._inner.is_monolithic
+
+    def apply(
+        self,
+        layer: FusedMoE,
+        x: torch.Tensor,
+        topk_weights: torch.Tensor,
+        topk_ids: torch.Tensor,
+        shared_experts_input: torch.Tensor | None,
+    ) -> torch.Tensor | tuple[torch.Tensor, torch.Tensor]:
+        return self._inner.apply(
+            layer, x, topk_weights, topk_ids, shared_experts_input)
+
+    def apply_monolithic(
+        self,
+        layer: FusedMoE,
+        x: torch.Tensor,
